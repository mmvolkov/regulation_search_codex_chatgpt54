# Public routing
PUBLIC_HOST=plequeneluera.beget.app
TRAEFIK_ACME_EMAIL=volkovmm@outlook.com

# Paths on Beget
PROJECT_ROOT=/opt/rag/RAG_Regulation_Search_Codex53
UPLOAD_DIR_ROOT=/tmp/rag_regulation_uploads

# Postgres bootstrap
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=postgres
POSTGRES_NON_ROOT_USER=n8n
POSTGRES_NON_ROOT_PASSWORD=change_me
POSTGRES_NON_ROOT_DB=n8n

# n8n
N8N_HOST=plequeneluera.beget.app
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_EDITOR_BASE_URL=https://plequeneluera.beget.app/
WEBHOOK_URL=https://plequeneluera.beget.app/
N8N_ENCRYPTION_KEY=change_me
N8N_RUNNERS_ENABLED=true
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false
N8N_SECURE_COOKIE=true
GENERIC_TIMEZONE=Europe/Moscow
EXECUTIONS_MODE=queue
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=change_me

# Shared app settings
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_ANSWER_MODEL=gpt-5.4
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=regulations_v2
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=bm25
CHUNK_MAX_CHARS=1200
INDEX_BATCH_SIZE=16
SEARCH_API_HOST=0.0.0.0
SEARCH_API_PORT=8000
