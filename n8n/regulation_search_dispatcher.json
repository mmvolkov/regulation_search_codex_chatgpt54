    {
      "parameters": {
        "jsCode": "const auth = $items('Resolve Authorization', 0, 0).json;\nconst payload = $json || {};\nconst hits = Array.isArray(payload.hits) ? payload.hits : Array.isArray(payload.fragments) ? payload.fragments : [];\nconst answer = String(payload.answer || hits[0]?.raw_text || hits[0]?.text || '').trim();\nconst documentRefs = hits.map((hit) => hit.doc_title || hit.doc_name || '').filter(Boolean).slice(0, 8).join(' | ');\nconst citations = hits.map((hit) => hit.citation || hit.heading || '').filter(Boolean).slice(0, 8).join(' | ');\nconst selectedChunksJson = JSON.stringify(hits.slice(0, 5)).slice(0, 45000);\nreturn [{\n  json: {\n    response: {\n      ...payload,\n      ok: true,\n      authorizedEmail: auth.email,\n      role: auth.role\n    },\n    logBody: {\n      majorDimension: 'ROWS',\n      values: [[\n        auth.requestedAt,\n        auth.requestId,\n        auth.email,\n        auth.role,\n        'search',\n        auth.query,\n        answer,\n        documentRefs,\n        citations,\n        selectedChunksJson,\n        String(hits.length),\n        String($execution.id)\n      ]]\n    }\n  }\n}];"
