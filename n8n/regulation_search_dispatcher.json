      "parameters": {
        "jsCode": "const request = $items('Normalize Request', 0, 0).json;\nconst values = Array.isArray($json.values) ? $json.values : [];\nconst normalize = (value) => String(value ?? '').trim().toLowerCase();\nconst truthy = new Set(['1', 'true', 'yes', 'y', 'active', 'enabled', 'allowed', 'ok']);\nconst falsy = new Set(['0', 'false', 'no', 'n', 'inactive', 'disabled', 'blocked', 'denied']);\n\nif (!request.email) {\n  return [{ json: { ...request, isAuthorized: false, authMessage: 'Укажите рабочий e-mail.', role: 'viewer', canUpload: false, canManageCollection: false } }];\n}\n\nif (values.length === 0) {\n  return [{ json: { ...request, isAuthorized: false, authMessage: 'Лист authorized_users пуст.', role: 'viewer', canUpload: false, canManageCollection: false } }];\n}\n\nconst headers = values[0].map(normalize);\nconst rows = values.slice(1);\nconst emailIndex = headers.findIndex((header) => ['email', 'e-mail', 'mail', 'user_email'].includes(header));\nconst roleIndex = headers.findIndex((header) => ['role', 'user_role', 'access_role'].includes(header));\nconst activeIndex = headers.findIndex((header) => ['active', 'enabled', 'is_active', 'allowed', 'status', 'access'].includes(header));\nconst nameIndex = headers.findIndex((header) => ['name', 'full_name', 'user_name'].includes(header));\n\nif (emailIndex === -1) {\n  return [{ json: { ...request, isAuthorized: false, authMessage: 'В листе authorized_users нет колонки email.', role: 'viewer', canUpload: false, canManageCollection: false } }];\n}\n\nconst email = normalize(request.email);\nconst matchedRow = rows.find((row) => normalize(row[emailIndex]) === email);\n\nif (!matchedRow) {\n  return [{ json: { ...request, isAuthorized: false, authMessage: 'Пользователь не найден в списке authorized_users.', role: 'viewer', canUpload: false, canManageCollection: false } }];\n}\n\nconst activeRaw = activeIndex >= 0 ? normalize(matchedRow[activeIndex]) : '';\nconst isActive = activeIndex === -1 || activeRaw === '' ? true : truthy.has(activeRaw) || !falsy.has(activeRaw);\nconst rawRole = roleIndex >= 0 ? normalize(matchedRow[roleIndex]) : 'viewer';\nconst role = ['admin', 'editor', 'viewer'].includes(rawRole) ? rawRole : 'viewer';\nconst displayName = nameIndex >= 0 ? String(matchedRow[nameIndex] || '').trim() : '';\n\nif (!isActive) {\n  return [{ json: { ...request, isAuthorized: false, authMessage: 'Доступ для пользователя отключён.', role, displayName, canUpload: false, canManageCollection: false } }];\n}\n\nreturn [{\n  json: {\n    ...request,\n    isAuthorized: true,\n    authMessage: 'Доступ подтверждён.',\n    role,\n    displayName,\n    canUpload: ['admin', 'editor'].includes(role),\n    canManageCollection: role === 'admin'\n  }\n}];"
