    {
      "parameters": {
        "jsCode": "const source = $json.body && typeof $json.body === 'object' ? $json.body : $json;\nconst headers = $json.headers || {};\nconst binary = $binary || {};\nconst binaryKeys = Object.keys(binary);\nconst allowedActions = new Set(['authorize', 'search', 'upload', 'collection_status', 'collection_clear']);\nconst action = String(source.action || $json.query?.action || '').trim().toLowerCase();\nif (!allowedActions.has(action)) {\n  throw new Error('Unsupported action. Expected authorize, search, upload, collection_status or collection_clear.');\n}\nconst email = String(source.email || source.userEmail || headers['x-user-email'] || headers['X-User-Email'] || '').trim().toLowerCase();\nconst parsedLimit = Number(source.limit || source.top_k || 6);\nconst limit = Number.isFinite(parsedLimit) ? Math.max(1, Math.min(12, Math.round(parsedLimit))) : 6;\nconst normalized = {\n  action,\n  email,\n  query: String(source.query || '').trim(),\n  limit,\n  preset: String(source.preset || 'balanced').trim() || 'balanced',\n  requestId: `${$execution.id}-${Date.now()}`,\n  requestedAt: new Date().toISOString(),\n  remoteIp: headers['x-forwarded-for'] || headers['x-real-ip'] || null,\n  userAgent: headers['user-agent'] || headers['User-Agent'] || null,\n  hasFile: binaryKeys.length > 0,\n  fileField: null,\n  originalFileName: null\n};\nif (binaryKeys.length > 0) {\n  const fileField = binary.file ? 'file' : binaryKeys[0];\n  normalized.fileField = fileField;\n  normalized.originalFileName = binary[fileField]?.fileName || 'document.docx';\n  return [{ json: normalized, binary: { file: binary[fileField] } }];\n}\nreturn [{ json: normalized }];"
