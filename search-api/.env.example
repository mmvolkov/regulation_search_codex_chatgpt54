# === Regulation Search v2 — Backend Configuration ===
#
# Copy this file to .env and fill in your values.
# These are SEPARATE from n8n's .env — this file is only for the search API container.

# --- Qdrant Cloud ---
QDRANT_URL=https://20b3f495-9d89-4be6-ac84-07a32c4651a2.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=regulations_v2

# --- OpenAI-compatible API (OpenRouter) ---
OPENAI_API_KEY=your-openrouter-api-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENAI_CHAT_MODEL=openai/gpt-4o-mini
EMBEDDING_DIMENSIONS=1536

# --- Search parameters ---
SEARCH_TOP_K=10
FINAL_TOP_K=5
RRF_K=60
